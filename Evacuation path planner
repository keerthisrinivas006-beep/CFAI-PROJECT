<script>
const RLETTERS=['A','B','C','D','E','F','G','H','I','J','K','L','M','N'];
const SPROW=[8,10,12,14,14,14,14,14,14,14,12,10,10,8];
const EXITS=[
  {id:'E1',label:'Front Left',side:'front',score:95,cap:120,time:25},
  {id:'E2',label:'Front Right',side:'front',score:92,cap:120,time:28},
  {id:'E3',label:'Mid Left',side:'left',score:88,cap:80,time:35},
  {id:'E4',label:'Mid Right',side:'right',score:85,cap:80,time:38},
  {id:'E5',label:'Rear Left',side:'rear',score:78,cap:60,time:52},
  {id:'E6',label:'Rear Right',side:'rear',score:75,cap:60,time:55},
];
let S={scen:'clear',blocked:new Set(),sel:null,alertN:0};

const SCENS={
  clear:{risk:0,rlbl:'NO RISK',rtag:'tg',ac:'ab-clear',aico:'✅',atxt:'All systems normal. No active emergencies. 6 exits fully operational.',exits:6,haz:0,routes:3,safe:97,xpct:100,et:'2:34',tw:'45s',tc:'+38s',tt:'83s',
    ai:'All exits operational. No hazards detected. Proceed to the nearest exit in an orderly fashion during evacuation.',
    steps:['Remain calm. Locate the nearest illuminated exit sign.','Follow the cyan route markers highlighted on floor displays.','Do not use elevators. Use stairs and maintain single-file movement.','Proceed to Assembly Point A in the main parking area.']},
  fire:{risk:82,rlbl:'HIGH RISK',rtag:'tr',ac:'ab-danger',aico:'🔥',atxt:'FIRE in front-left zone (Rows A–D). Exits E1 & E2 compromised. Evacuate via rear exits NOW!',exits:4,haz:1,routes:2,safe:34,xpct:67,et:'4:15',tw:'95s',tc:'+160s',tt:'255s',
    ai:'CRITICAL: Fire in front-left quadrant. Exits E1 & E2 are hazardous. Rerouting all occupants via E5/E6 (Rear) and E3 (Mid-Left). Low-density path via aisle D→K→Exit E5 detected.',
    steps:['🔥 DO NOT move toward the screen — fire is in the front zone.','↩ Reverse direction: move toward the rear of the hall.','🚪 Use Exit E5 (Rear Left) or E6 (Rear Right) as primary routes.','📞 Emergency services notified. ETA: 4 minutes. Await staff guidance.','🏁 Assemble at Point A (Parking) — away from the building.']},
  smoke:{risk:55,rlbl:'MEDIUM RISK',rtag:'ta',ac:'ab-warn',aico:'💨',atxt:'SMOKE in front section (Rows A–F). Reduced visibility. Mid and rear exits recommended.',exits:5,haz:1,routes:3,safe:58,xpct:83,et:'3:22',tw:'68s',tc:'+134s',tt:'202s',
    ai:'Smoke detected in front 6 rows. Visibility impaired. AI recommends Exit E3 (Mid Left) with 88/100 safety score as optimal safe route.',
    steps:['💨 Stay low — smoke rises. Crawl if visibility below 2 meters.','🧣 Cover mouth and nose with cloth to filter smoke.','🚪 Primary route: E3 (Mid Left) — clear of smoke, score 88.','⬆ Do not stand up until you have fully exited the building.','🏁 Assemble at Point B (Garden) — upwind from the building.']},
  power:{risk:38,rlbl:'LOW-MED RISK',rtag:'ta',ac:'ab-warn',aico:'⚡',atxt:'POWER FAILURE detected. Emergency lighting activated. All exits operational. Stay calm.',exits:6,haz:0,routes:3,safe:72,xpct:100,et:'3:45',tw:'75s',tc:'+150s',tt:'225s',
    ai:'Power failure detected. Emergency LED floor lighting is now active. All 6 exits remain fully operational. Follow floor-level lighting strips.',
    steps:['⚡ Remain calm. Emergency lighting activates within 3 seconds.','💡 Follow green LED strips on the floor — they lead to all exits.','📵 Use your phone screen as a light source if needed.','🚪 All 6 exits are operational. Proceed to the nearest exit.','🔦 Staff with flashlights are guiding occupants from all aisles.']},
  blocked:{risk:45,rlbl:'MEDIUM RISK',rtag:'ta',ac:'ab-warn',aico:'🚫',atxt:'EXIT BLOCKED. One or more exits unavailable. AI has recalculated optimal routes.',exits:5,haz:0,routes:2,safe:68,xpct:83,et:'3:10',tw:'58s',tc:'+130s',tt:'188s',
    ai:'One or more exits are blocked. AI has recalculated routes to nearest available exits. Follow yellow alternate route markers.',
    steps:['🚫 Blocked exits shown in red. Do not attempt to use them.','↩ Follow staff directions to alternate exit routes.','🚪 Use Exit E4 (Mid Right) or E6 (Rear Right) as alternatives.','📢 PA system will broadcast updated evacuation instructions.']}
};

function buildSeats(){
  const w=document.getElementById('seatsWrap'); w.innerHTML='';
  RLETTERS.forEach((L,ri)=>{
    const n=SPROW[ri];
    const row=document.createElement('div'); row.className='srow';
    const lbl=document.createElement('div'); lbl.className='rlbl'; lbl.textContent=L;
    row.appendChild(lbl);
    for(let si=0;si<n;si++){
      if([3,7].includes(si)){const g=document.createElement('div');g.className='seat sgap';g.style.width='7px';row.appendChild(g);}
      const s=document.createElement('div'); s.className='seat';
      s.dataset.r=L; s.dataset.c=si+1;
      if((L.charCodeAt(0)*31+si*17)%100<74){s.classList.add('occ');s.dataset.o=1;}
      s.addEventListener('click',()=>selSeat(L,si+1));
      row.appendChild(s);
    }
    w.appendChild(row);
  });
}

function selSeat(R,C){
  document.querySelectorAll('.seat.ssel').forEach(s=>s.classList.remove('ssel'));
  document.querySelectorAll('.seat').forEach(s=>{if(s.dataset.r===R&&parseInt(s.dataset.c)===C)s.classList.add('ssel');});
  S.sel={R,C}; drawRoutes();
  toast(`Seat ${R}${C} selected — computing routes…`,'tok','🪑');
}

function hazardSeats(){
  document.querySelectorAll('.seat').forEach(s=>{
    s.classList.remove('sdanger','sroute','ssafe');
    const ri=RLETTERS.indexOf(s.dataset.r);
    if(S.scen==='fire'){if(ri<4&&parseInt(s.dataset.c||1)<=6)s.classList.add('sdanger'); else if(ri>=10)s.classList.add('ssafe');}
    else if(S.scen==='smoke'){if(ri<6)s.classList.add('sdanger'); else if(ri>=10)s.classList.add('ssafe');}
    else if(S.scen==='power'){if((s.dataset.r.charCodeAt(0)+parseInt(s.dataset.c||1))%8===0)s.classList.add('sdanger');}
  });
  if(S.sel) drawRoutes();
}

function buildExitToggles(){
  const r=document.getElementById('exitTogRow'); r.innerHTML='';
  EXITS.forEach(e=>{
    const b=document.createElement('button');
    const bl=S.blocked.has(e.id);
    b.className='scbtn'+(bl?' sfire':'');
    b.textContent=(bl?'🔒 ':'🚪 ')+e.label;
    b.onclick=()=>togExit(e.id);
    r.appendChild(b);
  });
}

function togExit(id){
  if(S.blocked.has(id))S.blocked.delete(id);else S.blocked.add(id);
  const e=EXITS.find(x=>x.id===id),bl=S.blocked.has(id);
  buildExitToggles(); renderExits(); renderExitScores(); updateAll();
  addAlert(bl?'lcrit':'lok',bl?`Exit ${e.label} BLOCKED — rerouting!`:`Exit ${e.label} restored.`,bl?'🔒':'✅');
  toast(bl?`${e.label} blocked! Recalculating…`:`${e.label} restored!`,bl?'tdanger':'tok',bl?'🔒':'✅');
}

function renderExits(){
  const g=document.getElementById('exitsGrid'); g.innerHTML='';
  const avail=EXITS.filter(e=>!S.blocked.has(e.id));
  const best=avail.length?avail.reduce((a,b)=>adjScore(a)>adjScore(b)?a:b):null;
  EXITS.forEach(e=>{
    const bl=S.blocked.has(e.id);
    const sc=bl?0:adjScore(e);
    const d=document.createElement('div');
    d.className=`enode ${bl?'eblocked':'eopen'} ${(!bl&&e===best)?'ebest':''}`;
    d.innerHTML=`<div style="font-size:.9rem">${bl?'🔒':'🚪'}</div><div style="font-size:.67rem;font-weight:700">${e.label}</div><div class="escore">${bl?'BLOCKED':sc+'/100'}</div>`;
    g.appendChild(d);
  });
}

function adjScore(e){
  let s=e.score;
  if(S.scen==='fire'&&e.side==='front')s-=30;
  if(S.scen==='smoke'&&e.side==='front')s-=20;
  if(S.scen==='power')s-=8;
  if(S.blocked.has(e.id))s=0;
  return Math.max(0,Math.min(100,s));
}

function renderExitScores(){
  const el=document.getElementById('exitScores'); el.innerHTML='';
  EXITS.forEach(e=>{
    const bl=S.blocked.has(e.id),sc=adjScore(e);
    const col=bl?'var(--red)':sc>=80?'var(--green)':sc>=60?'var(--amber)':'var(--red)';
    el.innerHTML+=`<div style="margin-bottom:.35rem"><div style="display:flex;justify-content:space-between;font-size:.72rem;margin-bottom:2px"><span style="color:${bl?'var(--red)':'var(--text2)'}">${bl?'🔒':'→'} ${e.label}</span><span style="color:${col};font-family:var(--mono);font-weight:600">${bl?'BLOCKED':sc}</span></div><div class="ptrack"><div class="pfill" style="width:${sc}%;background:${col}"></div></div></div>`;
  });
}

function drawRoutes(){
  const svg=document.getElementById('rsvg'); svg.innerHTML='';
  const map=document.getElementById('cinemaMap');
  const W=map.clientWidth||500,H=map.clientHeight||280;
  const avail=EXITS.filter(e=>!S.blocked.has(e.id));
  if(!avail.length)return;
  const EP={E1:{x:W*.2,y:H*.96},E2:{x:W*.8,y:H*.96},E3:{x:.02*W,y:H*.55},E4:{x:.98*W,y:H*.55},E5:{x:W*.12,y:H*.88},E6:{x:W*.88,y:H*.88}};
  let sx=W/2,sy=H*.42;
  if(S.sel){
    const ri=RLETTERS.indexOf(S.sel.R);
    const n=SPROW[ri]||14;
    sx=W*.1+(S.sel.C/n)*(W*.8);
    sy=H*.1+(ri/14)*(H*.75);
  }
  if(S.scen==='fire'){
    const el=document.createElementNS('http://www.w3.org/2000/svg','ellipse');
    el.setAttribute('cx',W*.17);el.setAttribute('cy',H*.2);el.setAttribute('rx',W*.18);el.setAttribute('ry',H*.17);
    el.setAttribute('fill','rgba(220,38,38,.07)');el.setAttribute('stroke','rgba(220,38,38,.28)');el.setAttribute('stroke-width','1.5');el.setAttribute('stroke-dasharray','6 4');
    svg.appendChild(el);
    const ft=document.createElementNS('http://www.w3.org/2000/svg','text');
    ft.setAttribute('x',W*.17);ft.setAttribute('y',H*.2);ft.setAttribute('text-anchor','middle');
    ft.setAttribute('fill','rgba(220,38,38,.65)');ft.setAttribute('font-size','9');ft.setAttribute('font-family','Space Grotesk');
    ft.textContent='🔥 FIRE ZONE';svg.appendChild(ft);
  }
  const best=avail.reduce((a,b)=>adjScore(a)>adjScore(b)?a:b);
  const bp=EP[best.id];
  if(bp){
    const p=document.createElementNS('http://www.w3.org/2000/svg','path');
    const mx=(sx+bp.x)/2,my=Math.min(sy,bp.y)-35;
    p.setAttribute('d',`M${sx},${sy} Q${mx},${my} ${bp.x},${bp.y}`);
    p.setAttribute('class','route-path rp-best rp-anim');
    svg.appendChild(p);
    const c=document.createElementNS('http://www.w3.org/2000/svg','circle');
    c.setAttribute('cx',bp.x);c.setAttribute('cy',bp.y);c.setAttribute('r','6');c.setAttribute('fill','var(--cyan)');c.setAttribute('opacity','.85');
    svg.appendChild(c);
    const t=document.createElementNS('http://www.w3.org/2000/svg','text');
    t.setAttribute('x',bp.x);t.setAttribute('y',bp.y-12);t.setAttribute('text-anchor','middle');
    t.setAttribute('fill','var(--cyan)');t.setAttribute('font-size','7.5');t.setAttribute('font-family','Space Grotesk');t.setAttribute('font-weight','600');
    t.textContent='BEST EXIT';svg.appendChild(t);
  }
  avail.filter(e=>e.id!==best.id).slice(0,1).forEach(e=>{
    const ap=EP[e.id];if(!ap)return;
    const p=document.createElementNS('http://www.w3.org/2000/svg','path');
    const mx=(sx+ap.x)/2+(Math.random()>.5?25:-25),my=Math.min(sy,ap.y)-18;
    p.setAttribute('d',`M${sx},${sy} Q${mx},${my} ${ap.x},${ap.y}`);
    p.setAttribute('class','route-path rp-alt rp-anim');svg.appendChild(p);
  });
  const sd=document.createElementNS('http://www.w3.org/2000/svg','circle');
  sd.setAttribute('cx',sx);sd.setAttribute('cy',sy);sd.setAttribute('r','5');sd.setAttribute('fill','#fff');sd.setAttribute('opacity','.85');
  svg.appendChild(sd);
}

function renderRouteCmp(){
  const avail=EXITS.filter(e=>!S.blocked.has(e.id));
  const best=avail.length?avail.reduce((a,b)=>adjScore(a)>adjScore(b)?a:b,EXITS[0]):null;
  const fastest=avail.length?avail.reduce((a,b)=>a.time<b.time?a:b,EXITS[0]):null;
  const routes=[
    {name:'Shortest Path',ico:'⚡',bg:'rgba(0,212,255,.15)',col:'var(--cyan)',exit:avail[0]?.label||'N/A',time:avail[0]?.time||'-',score:avail[0]?adjScore(avail[0]):0,bars:[5,7,4,8,6,3]},
    {name:'Safest Path',ico:'🛡',bg:'rgba(16,185,129,.15)',col:'var(--green)',exit:best?.label||'N/A',time:best?.time||'-',score:best?adjScore(best):0,bars:[3,5,8,9,7,6]},
    {name:'Fastest Path',ico:'🏃',bg:'rgba(245,158,11,.15)',col:'var(--amber)',exit:fastest?.label||'N/A',time:fastest?.time||'-',score:avail.length?70:0,bars:[8,9,7,6,5,4]},
  ];
  document.getElementById('routeCmp').innerHTML=routes.map((r,i)=>`<div class="ritem${i===0?' ract':''}" onclick="this.parentNode.querySelectorAll('.ritem').forEach(x=>x.classList.remove('ract'));this.classList.add('ract')">
    <div class="rico" style="background:${r.bg};color:${r.col}">${r.ico}</div>
    <div style="flex:1"><div class="rname">${r.name}</div><div class="rmeta" style="color:${r.col}">→ ${r.exit} · ~${r.time}s · ${r.score}/100</div></div>
    <div class="rbars" style="color:${r.col}">${r.bars.map(h=>`<div class="rbar" style="height:${h*2}px"></div>`).join('')}</div>
  </div>`).join('');
}

function setRisk(p,lbl){
  const arc=document.getElementById('rArc'),dot=document.getElementById('rDot'),pctE=document.getElementById('rPct'),lblE=document.getElementById('rLbl'),tag=document.getElementById('rTag');
  const f=(p/100)*236;
  arc.setAttribute('stroke-dasharray',f+' 236');
  const col=p<30?'#10B981':p<60?'#F59E0B':'#DC2626';
  arc.setAttribute('stroke',col);pctE.textContent=p+'%';pctE.setAttribute('fill',col);lblE.textContent=lbl;
  const a=Math.PI+(p/100)*Math.PI,cx=90,cy=95,r=75;
  dot.setAttribute('cx',cx+r*Math.cos(a));dot.setAttribute('cy',cy+r*Math.sin(a));dot.setAttribute('fill',col);
  tag.className='tag '+(p<30?'tg':p<60?'ta':'tr');
  tag.textContent=p<30?'LOW RISK':p<60?'MEDIUM RISK':'HIGH RISK';
}

function setScen(type,btn){
  S.scen=type;
  document.querySelectorAll('.scbtn').forEach(b=>{b.className='scbtn';});
  btn.classList.add('s'+type);
  const d=SCENS[type];
  setRisk(d.risk,d.rlbl);
  const b=document.getElementById('abanner');
  b.className='alert-banner '+d.ac;
  document.getElementById('aico').textContent=d.aico;
  document.getElementById('atxt').textContent=d.atxt;
  document.getElementById('stExits').textContent=d.exits;
  document.getElementById('stHaz').textContent=d.haz;
  document.getElementById('stRoutes').textContent=d.routes;
  document.getElementById('safeP').textContent=d.safe+'/100';
  document.getElementById('safeB').style.width=d.safe+'%';
  document.getElementById('safeB').style.background=d.safe>80?'var(--green)':d.safe>50?'var(--amber)':'var(--red)';
  document.getElementById('exitP').textContent=d.xpct+'%';
  document.getElementById('exitB').style.width=d.xpct+'%';
  document.getElementById('exitB').style.background=d.xpct>80?'var(--green)':d.xpct>50?'var(--amber)':'var(--red)';
  document.getElementById('evacTime').textContent=d.et;
  document.getElementById('tWalk').textContent=d.tw;
  document.getElementById('tCrowd').textContent=d.tc;
  document.getElementById('tTotal').textContent=d.tt;
  document.getElementById('aiMsg').textContent=d.ai;
  document.getElementById('aiSteps').innerHTML=d.steps.map((s,i)=>`<div class="ai-step"><div class="ai-snum">${i+1}</div><div>${s}</div></div>`).join('');
  const sp=document.getElementById('sysPill');
  if(type!=='clear'){sp.className='status-pill pill-danger';sp.innerHTML='<span class="blink">●</span>EMERGENCY';}
  else{sp.className='status-pill pill-ok';sp.innerHTML='<span class="blink">●</span>SYSTEM ONLINE';}
  if(type==='fire'){S.blocked.add('E1');S.blocked.add('E2');}
  else if(type==='clear')S.blocked.clear();
  hazardSeats();renderExits();renderExitScores();drawRoutes();buildExitToggles();renderRouteCmp();renderTp();drawHeat();drawCrowd();
  addAlert(type==='clear'?'lok':type==='fire'?'lcrit':'lwarn',d.atxt,d.aico);
  if(type!=='clear')toast(d.atxt.slice(0,55)+'…',type==='fire'?'tdanger':'twarn',d.aico);
}

function drawHeat(){
  const c=document.getElementById('heatC'),ctx=c.getContext('2d'),W=c.width,H=c.height;
  ctx.clearRect(0,0,W,H);ctx.fillStyle='#060912';ctx.fillRect(0,0,W,H);
  ctx.strokeStyle='rgba(255,255,255,.03)';ctx.lineWidth=.8;
  for(let i=0;i<=7;i++){ctx.beginPath();ctx.moveTo(i*W/7,0);ctx.lineTo(i*W/7,H);ctx.stroke();}
  for(let i=0;i<=4;i++){ctx.beginPath();ctx.moveTo(0,i*H/4);ctx.lineTo(W,i*H/4);ctx.stroke();}
  const pts=[];
  if(S.scen==='fire'){pts.push({x:.15*W,y:.18*H,r:75,t:'fire',i:.9},{x:.24*W,y:.32*H,r:55,t:'fire',i:.65},{x:.08*W,y:.52*H,r:40,t:'warn',i:.45});}
  else if(S.scen==='smoke'){pts.push({x:.5*W,y:.15*H,r:115,t:'smoke',i:.6},{x:.28*W,y:.28*H,r:70,t:'smoke',i:.5});}
  else if(S.scen==='power'){pts.push({x:.65*W,y:.45*H,r:38,t:'warn',i:.3},{x:.3*W,y:.62*H,r:38,t:'warn',i:.28});}
  pts.push({x:.52*W,y:.55*H,r:48,t:'crowd',i:.28},{x:.72*W,y:.68*H,r:42,t:'crowd',i:.32},{x:.3*W,y:.72*H,r:38,t:'crowd',i:.22});
  pts.forEach(p=>{
    const g=ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,p.r);
    const c1s={fire:`rgba(139,0,0,${p.i})`,smoke:`rgba(100,116,139,${p.i})`,warn:`rgba(245,158,11,${p.i})`,crowd:`rgba(245,158,11,${p.i})`}[p.t];
    const c2s={fire:'rgba(220,38,38,0)',smoke:'rgba(100,116,139,0)',warn:'rgba(245,158,11,0)',crowd:'rgba(245,158,11,0)'}[p.t];
    g.addColorStop(0,c1s);g.addColorStop(1,c2s);
    ctx.fillStyle=g;ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fill();
  });
  ctx.strokeStyle='rgba(255,255,255,.07)';ctx.lineWidth=1.5;ctx.strokeRect(W*.05,H*.05,W*.9,H*.88);
  ctx.fillStyle='rgba(0,212,255,.06)';ctx.fillRect(W*.07,H*.06,W*.86,H*.05);
  ctx.strokeStyle='rgba(0,212,255,.18)';ctx.strokeRect(W*.07,H*.06,W*.86,H*.05);
  ctx.fillStyle='rgba(0,212,255,.35)';ctx.font='7px Space Grotesk';ctx.textAlign='center';ctx.fillText('SCREEN',W/2,H*.1);
  if(S.scen==='fire'){ctx.fillStyle='rgba(255,100,50,.7)';ctx.font='bold 8px Space Grotesk';ctx.fillText('🔥 FIRE ZONE',W*.15,H*.28);}
}

function drawCrowd(){
  const c=document.getElementById('crowdC'),ctx=c.getContext('2d'),W=c.width,H=c.height;
  ctx.clearRect(0,0,W,H);ctx.fillStyle='#060912';ctx.fillRect(0,0,W,H);
  RLETTERS.forEach((L,ri)=>{
    const n=SPROW[ri];
    for(let si=0;si<n;si++){
      const x=W*.08+(si/14)*(W*.84),y=H*.1+(ri/14)*(H*.82);
      const h=(L.charCodeAt(0)*31+si*17)%100,occ=h<74;
      let col='rgba(255,255,255,.04)';
      if(occ){
        const dh=(L.charCodeAt(0)+si)%10;
        col=dh<3?'rgba(220,38,38,.75)':dh<6?'rgba(245,158,11,.65)':'rgba(16,185,129,.55)';
      }
      if(S.scen==='fire'&&ri<4&&si<6)col='rgba(220,38,38,.9)';
      ctx.fillStyle=col;ctx.beginPath();ctx.arc(x,y,2.8,0,Math.PI*2);ctx.fill();
    }
  });
  ctx.fillStyle='rgba(0,212,255,.07)';ctx.fillRect(W*.07,H*.03,W*.86,H*.05);
  ctx.strokeStyle='rgba(0,212,255,.18)';ctx.lineWidth=1;ctx.strokeRect(W*.07,H*.03,W*.86,H*.05);
  ctx.fillStyle='rgba(0,212,255,.4)';ctx.font='6.5px Space Grotesk';ctx.textAlign='center';ctx.fillText('SCREEN',W/2,H*.07);
}

function renderTp(){
  const el=document.getElementById('tpBars');
  el.innerHTML=EXITS.map(e=>{
    const bl=S.blocked.has(e.id);
    const tp=bl?0:Math.round(e.cap*(S.scen==='fire'&&e.side==='front'?.15:1));
    const p=Math.min(100,(tp/120)*100);
    const col=bl?'var(--red)':p>70?'var(--green)':p>40?'var(--amber)':'var(--red)';
    return `<div class="prow" style="margin-bottom:.3rem"><div class="plbl"><span style="font-size:.7rem;color:${bl?'var(--red)':'var(--text2)'}">${bl?'🔒 ':''}${e.label}</span><span style="color:${col};font-family:var(--mono)">${tp}/min</span></div><div class="ptrack"><div class="pfill" style="width:${p}%;background:${col}"></div></div></div>`;
  }).join('');
  document.getElementById('zoneBars').innerHTML=[
    {n:'Front Zone (A–D)',o:98},{n:'Mid Zone (E–H)',o:72},{n:'Rear Zone (I–N)',o:55}
  ].map(z=>{const col=z.o>85?'var(--red)':z.o>65?'var(--amber)':'var(--green)';return`<div class="prow" style="margin-bottom:.3rem"><div class="plbl"><span style="font-size:.7rem;color:var(--text2)">${z.n}</span><span style="color:${col};font-family:var(--mono)">${z.o}%</span></div><div class="ptrack"><div class="pfill" style="width:${z.o}%;background:${col}"></div></div></div>`;}).join('');
  const hc=document.getElementById('histChart');
  const times=[180,210,155,245,190,220,165],days=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],mx=Math.max(...times);
  hc.innerHTML=times.map((t,i)=>{const h=Math.round((t/mx)*72);return`<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px"><div style="font-size:.58rem;color:var(--text3);font-family:var(--mono)">${t}</div><div style="height:${h}px;width:100%;border-radius:3px 3px 0 0;background:${i===new Date().getDay()?'var(--cyan)':'rgba(255,255,255,.1)'};transition:height .5s"></div><div style="font-size:.58rem;color:var(--text3)">${days[i]}</div></div>`;}).join('');
}

function addAlert(cls,msg,ico){
  const log=document.getElementById('alog');
  const now=new Date().toTimeString().slice(0,8);
  const d=document.createElement('div');d.className=`litem ${cls}`;
  d.innerHTML=`<div class="lico">${ico}</div><div><div class="lmsg">${msg}</div><div class="ltime">${now}</div></div>`;
  log.insertBefore(d,log.firstChild);
  while(log.children.length>18)log.removeChild(log.lastChild);
  S.alertN++;document.getElementById('alertCnt').textContent=S.alertN+' ALERTS';
}

function toast(msg,cls='',ico='🔔'){
  const box=document.getElementById('toast');
  const d=document.createElement('div');d.className=`titem ${cls}`;
  d.innerHTML=`<span style="font-size:1rem">${ico}</span><span style="flex:1;line-height:1.4">${d.textContent||msg}</span>`;
  d.querySelector('span:last-child').textContent=msg;
  box.appendChild(d);
  setTimeout(()=>{d.classList.add('rem');setTimeout(()=>d.remove(),300);},3200);
}

function updateAll(){renderExits();renderExitScores();renderRouteCmp();renderTp();hazardSeats();drawRoutes();drawHeat();drawCrowd();}

function initSteps(){
  const d=SCENS.clear;
  document.getElementById('aiMsg').textContent=d.ai;
  document.getElementById('aiSteps').innerHTML=d.steps.map((s,i)=>`<div class="ai-step"><div class="ai-snum">${i+1}</div><div>${s}</div></div>`).join('');
}

setInterval(()=>{const n=new Date().toTimeString().slice(0,8);document.getElementById('atime').textContent=n;},1000);

window.addEventListener('load',()=>{
  buildSeats();buildExitToggles();renderExits();renderExitScores();renderRouteCmp();renderTp();drawHeat();drawCrowd();setRisk(0,'NO RISK');initSteps();
  addAlert('lok','System initialized. All sensors online.','✅');
  addAlert('linfo','Crowd density sensors calibrated. 312 occupants detected.','ℹ️');
  addAlert('lok','All 6 emergency exits verified operational.','🚪');
  setTimeout(()=>{selSeat('G',7);toast('Welcome to CineGuard AI. Click any seat or choose an emergency scenario.','tok','🎬');},700);
});
window.addEventListener('resize',()=>{drawHeat();drawCrowd();drawRoutes();});
</script>
