<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>CineGuard AI — Cinema Hall Emergency Evacuation System</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');
:root{--bg:#080B14;--bg2:#0D1120;--bg3:#111827;--red:#DC2626;--red2:#EF4444;--red3:rgba(220,38,38,.15);--cyan:#00D4FF;--cyan2:#22D3EE;--cyan3:rgba(0,212,255,.12);--amber:#F59E0B;--amber2:#FCD34D;--amber3:rgba(245,158,11,.15);--green:#10B981;--green2:#34D399;--green3:rgba(16,185,129,.15);--purple:#8B5CF6;--purple3:rgba(139,92,246,.15);--text:#F1F5F9;--text2:#94A3B8;--text3:#64748B;--border:rgba(255,255,255,.07);--border2:rgba(255,255,255,.12);--glass:rgba(255,255,255,.04);--font:'Space Grotesk',system-ui,sans-serif;--mono:'JetBrains Mono',monospace}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--font);overflow-x:hidden;min-height:100vh}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:56px;background:rgba(8,11,20,.9);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 1.5rem;gap:1rem}
.nav-logo{display:flex;align-items:center;gap:.6rem;font-size:1.05rem;font-weight:700;color:#fff;white-space:nowrap}
.pulse-dot{width:8px;height:8px;border-radius:50%;background:var(--red);animation:pdot 1.4s ease-in-out infinite}
@keyframes pdot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.8)}}
.nav-center{flex:1;text-align:center;font-size:.75rem;color:var(--text3);display:none}
@media(min-width:700px){.nav-center{display:block}}
.status-pill{padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:700;border:1px solid;display:flex;align-items:center;gap:5px;cursor:default}
.pill-ok{background:var(--green3);border-color:var(--green);color:var(--green2)}
.pill-danger{background:var(--red3);border-color:var(--red);color:var(--red2)}
.blink{animation:blinka 1s step-end infinite}
@keyframes blinka{0%,100%{opacity:1}50%{opacity:0}}
.hero{padding:76px 1.5rem 0;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 50% at 50% 30%,rgba(220,38,38,.07),transparent),radial-gradient(ellipse 50% 40% at 80% 70%,rgba(0,212,255,.06),transparent);pointer-events:none}
.hero-eye{font-size:.72rem;letter-spacing:.15em;text-transform:uppercase;color:var(--cyan);margin-bottom:.6rem;font-weight:600}
.hero-h1{font-size:clamp(1.7rem,4vw,3rem);font-weight:700;line-height:1.1;color:#fff;margin-bottom:.6rem}
.hero-h1 em{color:var(--red2);font-style:normal}
.hero-sub{font-size:.92rem;color:var(--text2);max-width:520px;margin:0 auto 1.2rem;line-height:1.7}
.htags{display:flex;flex-wrap:wrap;gap:.4rem;justify-content:center;margin-bottom:1.8rem}
.tag{padding:3px 11px;border-radius:20px;font-size:.7rem;font-weight:600;border:1px solid}
.tg{background:var(--green3);border-color:rgba(16,185,129,.4);color:var(--green2)}
.tc{background:var(--cyan3);border-color:rgba(0,212,255,.3);color:var(--cyan2)}
.ta{background:var(--amber3);border-color:rgba(245,158,11,.4);color:var(--amber2)}
.tr{background:var(--red3);border-color:rgba(220,38,38,.4);color:var(--red2)}
.tp{background:var(--purple3);border-color:rgba(139,92,246,.4);color:#A78BFA}
.alert-banner{margin:0 1.5rem 1.2rem;border-radius:10px;padding:.75rem 1.1rem;display:flex;align-items:center;gap:.7rem;font-size:.83rem;font-weight:500;border:1px solid;transition:all .4s}
.ab-clear{background:var(--green3);border-color:var(--green);color:var(--green2)}
.ab-warn{background:var(--amber3);border-color:var(--amber);color:var(--amber2)}
.ab-danger{background:var(--red3);border-color:var(--red);color:var(--red2);animation:flashb 1s ease-in-out infinite}
@keyframes flashb{0%,100%{box-shadow:0 0 0 0 rgba(220,38,38,.3)}50%{box-shadow:0 0 0 4px rgba(220,38,38,.1)}}
.main{padding:0 1.5rem 3rem;max-width:1400px;margin:0 auto;display:flex;flex-direction:column;gap:1.2rem}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem}
.row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.2rem}
.row13{display:grid;grid-template-columns:1fr 330px;gap:1.2rem}
@media(max-width:1100px){.row13{grid-template-columns:1fr}}
@media(max-width:800px){.row2,.row3{grid-template-columns:1fr}}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:14px;overflow:hidden}
.ch{padding:.85rem 1.1rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:.6rem}
.ct{font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--text2);display:flex;align-items:center;gap:.4rem}
.cbadge{font-size:.65rem;padding:2px 8px;border-radius:10px;font-weight:700;background:var(--cyan3);color:var(--cyan);border:1px solid rgba(0,212,255,.2)}
.cb{padding:1.1rem}
.slbl{font-size:.68rem;text-transform:uppercase;letter-spacing:.12em;color:var(--text3);margin-bottom:.6rem;display:flex;align-items:center;gap:.5rem}
.slbl::after{content:'';flex:1;height:1px;background:var(--border)}
.scrow{display:flex;flex-wrap:wrap;gap:.5rem}
.scbtn{padding:6px 13px;border-radius:8px;border:1px solid var(--border2);background:var(--glass);color:var(--text2);font-size:.78rem;font-family:var(--font);font-weight:500;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:5px}
.scbtn:hover{border-color:var(--cyan);color:#fff;background:var(--cyan3)}
.scbtn.sfire{background:var(--red3);border-color:var(--red);color:var(--red2)}
.scbtn.ssmoke{background:rgba(100,116,139,.15);border-color:#64748B;color:#94A3B8}
.scbtn.spower{background:var(--purple3);border-color:var(--purple);color:#A78BFA}
.scbtn.sblocked{background:var(--amber3);border-color:var(--amber);color:var(--amber2)}
.scbtn.sclear{background:var(--green3);border-color:var(--green);color:var(--green2)}
.screen-lbl{text-align:center;padding:.6rem;background:linear-gradient(to bottom,rgba(0,212,255,.08),transparent);border-bottom:2px solid rgba(0,212,255,.2);font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;color:var(--cyan);font-weight:600}
.seats-wrap{padding:.4rem .6rem .8rem}
.srow{display:flex;align-items:center;gap:3px;margin-bottom:3px;justify-content:center}
.rlbl{font-size:.58rem;color:var(--text3);width:12px;text-align:right;flex-shrink:0;font-family:var(--mono)}
.seat{width:15px;height:12px;border-radius:3px 3px 1px 1px;border:1px solid rgba(255,255,255,.07);background:rgba(255,255,255,.05);cursor:pointer;transition:all .15s;flex-shrink:0}
.seat:hover{border-color:rgba(255,255,255,.3);transform:scaleY(1.15)}
.seat.occ{background:rgba(255,255,255,.17);border-color:rgba(255,255,255,.22)}
.seat.sdanger{background:rgba(220,38,38,.6);border-color:var(--red);animation:sdang .8s ease-in-out infinite alternate}
.seat.sroute{background:rgba(0,212,255,.45);border-color:var(--cyan);animation:srout 1s ease-in-out infinite alternate}
.seat.ssafe{background:rgba(16,185,129,.4);border-color:var(--green)}
.seat.ssel{background:var(--cyan);border-color:#fff;box-shadow:0 0 8px var(--cyan)}
.seat.sgap{background:transparent;border-color:transparent;cursor:default}
@keyframes sdang{from{background:rgba(220,38,38,.35)}to{background:rgba(220,38,38,.8)}}
@keyframes srout{from{background:rgba(0,212,255,.25)}to{background:rgba(0,212,255,.65)}}
.exits-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.35rem;padding:.3rem .6rem .7rem}
.enode{padding:.35rem .5rem;border-radius:7px;border:1px solid;font-size:.68rem;font-weight:600;text-align:center;cursor:pointer;transition:all .2s}
.eopen{background:var(--green3);border-color:var(--green);color:var(--green2)}
.eopen:hover{background:rgba(16,185,129,.25)}
.eblocked{background:var(--red3);border-color:var(--red);color:var(--red2)}
.ebest{box-shadow:0 0 12px rgba(16,185,129,.4);border-width:2px}
.escore{font-size:.6rem;font-weight:400;opacity:.8;margin-top:1px}
.route-path{fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round}
.rp-best{stroke:var(--cyan);stroke-width:3;filter:drop-shadow(0 0 4px var(--cyan));stroke-dasharray:10 5}
.rp-alt{stroke:var(--amber);stroke-width:1.8;opacity:.55;stroke-dasharray:6 4}
@keyframes dash{to{stroke-dashoffset:-30}}
.rp-anim{animation:dash 1s linear infinite}
.time-big{font-size:3rem;font-weight:700;font-family:var(--mono);color:var(--cyan);text-align:center;line-height:1;text-shadow:0 0 30px rgba(0,212,255,.35)}
.tunit{font-size:.72rem;color:var(--text2);text-align:center;margin-top:.2rem}
.tbreak{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.5rem;margin-top:.9rem}
.tseg{text-align:center;padding:.45rem;background:var(--glass);border-radius:7px;border:1px solid var(--border)}
.tseg .tnum{font-size:1rem;font-weight:700;font-family:var(--mono)}
.tseg .tnlbl{font-size:.62rem;color:var(--text2);margin-top:2px}
.sgrid{display:grid;grid-template-columns:1fr 1fr;gap:.9rem}
.smin .val{font-size:1.5rem;font-weight:700;line-height:1;font-family:var(--mono)}
.smin .lbl{font-size:.68rem;color:var(--text2);text-transform:uppercase;letter-spacing:.07em}
.smin .sub{font-size:.65rem;color:var(--text3)}
.prow{margin-bottom:.6rem}
.plbl{display:flex;justify-content:space-between;font-size:.72rem;color:var(--text2);margin-bottom:.25rem}
.ptrack{height:5px;background:rgba(255,255,255,.06);border-radius:3px;overflow:hidden}
.pfill{height:100%;border-radius:3px;transition:width 1s ease}
.ai-msg{background:var(--glass);border:1px solid var(--border);border-radius:9px;padding:.85rem 1rem;font-size:.8rem;line-height:1.7;color:var(--text2);position:relative}
.ai-msg::before{content:'AI';position:absolute;top:-8px;left:12px;background:var(--cyan);color:#000;font-size:.58rem;font-weight:800;padding:1px 7px;border-radius:4px;letter-spacing:.07em}
.ai-steps{margin-top:.7rem;display:flex;flex-direction:column;gap:.35rem}
.ai-step{display:flex;align-items:flex-start;gap:.45rem;font-size:.76rem;color:var(--text2)}
.ai-snum{background:var(--cyan3);border:1px solid rgba(0,212,255,.3);color:var(--cyan);border-radius:50%;width:17px;height:17px;display:flex;align-items:center;justify-content:center;font-size:.62rem;font-weight:700;flex-shrink:0;margin-top:1px}
.route-cmp{display:flex;flex-direction:column;gap:.5rem}
.ritem{border:1px solid var(--border);border-radius:9px;padding:.65rem .9rem;display:flex;align-items:center;gap:.7rem;cursor:pointer;transition:all .2s}
.ritem:hover{border-color:var(--border2);background:var(--glass)}
.ritem.ract{border-color:var(--cyan);background:var(--cyan3)}
.rico{width:32px;height:32px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0}
.rname{font-size:.8rem;font-weight:600;color:#fff;margin-bottom:1px}
.rmeta{font-size:.7rem;color:var(--text2)}
.rbars{display:flex;gap:2px;align-items:flex-end;height:18px}
.rbar{width:4px;border-radius:2px;background:currentColor;opacity:.7}
.log-list{display:flex;flex-direction:column;gap:.45rem;max-height:200px;overflow-y:auto}
.litem{display:flex;align-items:flex-start;gap:.6rem;padding:.55rem .75rem;border-radius:8px;border:1px solid;font-size:.76rem}
.linfo{background:var(--cyan3);border-color:rgba(0,212,255,.2);color:var(--cyan2)}
.lwarn{background:var(--amber3);border-color:rgba(245,158,11,.25);color:var(--amber2)}
.lcrit{background:var(--red3);border-color:rgba(220,38,38,.25);color:var(--red2)}
.lok{background:var(--green3);border-color:rgba(16,185,129,.25);color:var(--green2)}
.lico{font-size:.85rem;flex-shrink:0;margin-top:1px}
.lmsg{font-weight:500;line-height:1.4}
.ltime{font-size:.63rem;opacity:.7;font-family:var(--mono);margin-top:2px}
.tips-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(185px,1fr));gap:.7rem}
.tip{background:var(--glass);border:1px solid var(--border);border-radius:10px;padding:.9rem;transition:border-color .2s}
.tip:hover{border-color:var(--border2)}
.tpico{font-size:1.4rem;margin-bottom:.4rem}
.tptitle{font-size:.8rem;font-weight:600;color:#fff;margin-bottom:.25rem}
.tptxt{font-size:.73rem;color:var(--text2);line-height:1.6}
#toast{position:fixed;top:66px;right:1rem;z-index:500;display:flex;flex-direction:column;gap:.45rem;max-width:300px}
.titem{background:rgba(13,17,32,.96);border:1px solid var(--border2);border-radius:10px;padding:.7rem .9rem;font-size:.78rem;display:flex;align-items:center;gap:.55rem;box-shadow:0 8px 28px rgba(0,0,0,.45);animation:slin .3s ease;backdrop-filter:blur(20px)}
.titem.rem{animation:slout .3s ease forwards}
.tdanger{border-color:var(--red)}
.twarn{border-color:var(--amber)}
.tok{border-color:var(--green)}
@keyframes slin{from{transform:translateX(110%);opacity:0}to{transform:translateX(0);opacity:1}}
@keyframes slout{to{transform:translateX(110%);opacity:0}}
footer{border-top:1px solid var(--border);padding:1.3rem;text-align:center;font-size:.75rem;color:var(--text3);margin-top:.5rem}
footer span{color:var(--cyan)}
</style>
</head>
<body>
<div id="toast"></div>
<nav>
  <div class="nav-logo"><div class="pulse-dot"></div>CineGuard<span style="color:var(--cyan)">AI</span></div>
  <div class="nav-center">Cinema Hall Emergency Evacuation System · Multiplex Central · Hall 3</div>
  <div id="sysPill" class="status-pill pill-ok"><span class="blink">●</span>SYSTEM ONLINE</div>
</nav>

<div class="hero">
  <div class="hero-eye">Smart Emergency Safety Platform · AI-Powered</div>
  <h1 class="hero-h1">Cinema Hall <em>Emergency</em><br/>Evacuation Planner</h1>
  <p class="hero-sub">Real-time AI evacuation route computation for Multiplex Central Hall 3 — 420 seats · 6 emergency exits · Live hazard tracking · A* pathfinding.</p>
  <div class="htags">
    <span class="tag tc">A* Pathfinding</span><span class="tag tr">Fire Detection</span><span class="tag ta">Crowd Density</span><span class="tag tg">Live Routing</span><span class="tag tp">Risk Analytics</span>
  </div>
</div>
<div style="height:.8rem"></div>
<div class="alert-banner ab-clear" id="abanner">
  <span id="aico" style="font-size:1.2rem">✅</span>
  <span id="atxt" style="flex:1">All systems normal. No active emergencies. 6 exits fully operational.</span>
  <span id="atime" style="font-family:var(--mono);font-size:.7rem;opacity:.7">12:00:00</span>
</div>

<div class="main">

<!-- ROW 1: SCENARIO + RISK -->
<div class="row2" style="grid-template-columns:1fr 220px">
  <div class="card">
    <div class="ch"><div class="ct">🎬 Emergency Scenario Control</div><div class="cbadge">INTERACTIVE</div></div>
    <div class="cb">
      <div class="slbl">Active emergency type</div>
      <div class="scrow">
        <button class="scbtn sclear" onclick="setScen('clear',this)">✅ All Clear</button>
        <button class="scbtn" onclick="setScen('fire',this)">🔥 Fire Emergency</button>
        <button class="scbtn" onclick="setScen('smoke',this)">💨 Smoke Alert</button>
        <button class="scbtn" onclick="setScen('power',this)">⚡ Power Failure</button>
        <button class="scbtn" onclick="setScen('blocked',this)">🚫 Exit Blocked</button>
      </div>
      <div style="margin-top:.9rem">
        <div class="slbl">Toggle exits blocked/open</div>
        <div id="exitTogRow" class="scrow"></div>
      </div>
    </div>
  </div>
  <div class="card">
    <div class="ch"><div class="ct">⚠️ Risk Level</div></div>
    <div class="cb" style="text-align:center;padding:.8rem">
      <svg viewBox="0 0 180 100" style="width:100%;max-width:170px;display:block;margin:0 auto">
        <defs>
          <linearGradient id="rg" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#10B981"/><stop offset="50%" stop-color="#F59E0B"/><stop offset="100%" stop-color="#DC2626"/>
          </linearGradient>
          <filter id="gf"><feGaussianBlur stdDeviation="2.5" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
        </defs>
        <path d="M15 95 A75 75 0 0 1 165 95" fill="none" stroke="rgba(255,255,255,.06)" stroke-width="14" stroke-linecap="round"/>
        <path d="M15 95 A75 75 0 0 1 165 95" fill="none" stroke="url(#rg)" stroke-width="14" stroke-linecap="round" opacity=".2"/>
        <path id="rArc" d="M15 95 A75 75 0 0 1 165 95" fill="none" stroke="url(#rg)" stroke-width="14" stroke-linecap="round" stroke-dasharray="0 236"/>
        <circle id="rDot" cx="15" cy="95" r="6" fill="#10B981" filter="url(#gf)"/>
        <text id="rPct" x="90" y="76" text-anchor="middle" font-size="20" font-weight="700" fill="white" font-family="JetBrains Mono">0%</text>
        <text id="rLbl" x="90" y="89" text-anchor="middle" font-size="7.5" fill="#64748B" font-family="Space Grotesk">NO RISK</text>
      </svg>
      <div id="rTag" class="tag tg" style="display:inline-block;margin-top:.2rem;font-size:.72rem">LOW RISK</div>
    </div>
  </div>
</div>

<!-- ROW 2: MAP + SIDEBAR -->
<div class="row13">
  <div class="card">
    <div class="ch"><div class="ct">🗺 Cinema Hall Floor Map — Hall 3</div><span style="font-size:.7rem;color:var(--text3)">Click any seat</span></div>
    <div class="cb" style="padding:.7rem">
      <div id="cinemaMap" style="position:relative;background:#060912;border-radius:8px;overflow:hidden">
        <div class="screen-lbl">◀️ ═══════ CINEMA SCREEN ═══════ ▶️</div>
        <div class="seats-wrap" id="seatsWrap"></div>
        <svg id="rsvg" style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none"></svg>
      </div>
      <div class="slbl" style="margin-top:.8rem">Emergency exits — click to toggle</div>
      <div class="exits-grid" id="exitsGrid"></div>
      <div style="display:flex;flex-wrap:wrap;gap:.6rem;margin-top:.5rem;font-size:.68rem;color:var(--text2)">
        <span>⬜ Empty</span><span style="color:rgba(255,255,255,.7)">▪ Occupied</span><span style="color:var(--red2)">▪ Danger</span><span style="color:var(--cyan2)">▪ Route</span><span style="color:var(--green2)">▪ Safe</span><span style="color:var(--cyan)">▪ Selected</span>
      </div>
    </div>
  </div>

  <div style="display:flex;flex-direction:column;gap:1.2rem">
    <div class="card">
      <div class="ch"><div class="ct">⏱ Evacuation Time</div></div>
      <div class="cb">
        <div class="time-big" id="evacTime">2:34</div>
        <div class="tunit">estimated min : sec</div>
        <div class="tbreak">
          <div class="tseg"><div class="tnum" id="tWalk" style="color:var(--cyan)">45s</div><div class="tnlbl">Walk time</div></div>
          <div class="tseg"><div class="tnum" id="tCrowd" style="color:var(--amber)">+38s</div><div class="tnlbl">Crowd delay</div></div>
          <div class="tseg"><div class="tnum" id="tTotal" style="color:var(--green)">83s</div><div class="tnlbl">Total</div></div>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="ch"><div class="ct">📊 Live Statistics</div></div>
      <div class="cb">
        <div class="sgrid">
          <div class="smin"><div class="val" id="stOcc" style="color:var(--cyan)">312</div><div class="lbl">Occupancy</div><div class="sub">of 420 seats</div></div>
          <div class="smin"><div class="val" id="stExits" style="color:var(--green)">6</div><div class="lbl">Active Exits</div><div class="sub">operational</div></div>
          <div class="smin"><div class="val" id="stRoutes" style="color:var(--amber)">3</div><div class="lbl">Alt Routes</div><div class="sub">computed</div></div>
          <div class="smin"><div class="val" id="stHaz" style="color:var(--red)">0</div><div class="lbl">Hazard Zones</div><div class="sub">detected</div></div>
        </div>
        <div style="margin-top:.9rem">
          <div class="prow"><div class="plbl"><span>Capacity</span><span id="capP" style="font-family:var(--mono)">74%</span></div><div class="ptrack"><div class="pfill" id="capB" style="width:74%;background:var(--cyan)"></div></div></div>
          <div class="prow"><div class="plbl"><span>Exits available</span><span id="exitP" style="font-family:var(--mono)">100%</span></div><div class="ptrack"><div class="pfill" id="exitB" style="width:100%;background:var(--green)"></div></div></div>
